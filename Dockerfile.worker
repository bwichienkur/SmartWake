FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src
COPY SmsPlatform.sln ./
COPY src/ ./src/
RUN dotnet restore
RUN dotnet publish src/SmsPlatform.Worker/SmsPlatform.Worker.csproj -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:9.0
WORKDIR /app
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "SmsPlatform.Worker.dll"]
